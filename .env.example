# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Admin Credentials (REQUIRED for production)
REACT_APP_ADMIN_USERNAME=aselga
REACT_APP_ADMIN_PASSWORD_HASH=your-hashed-password-here
REACT_APP_SALT_KEY=your-random-salt-key-here

# Security Configuration
REACT_APP_SESSION_DURATION=86400000
REACT_APP_MAX_LOGIN_ATTEMPTS=5
REACT_APP_LOCKOUT_DURATION=1800000

# API Configuration (if using backend)
REACT_APP_API_URL=https://your-api-domain.com
REACT_APP_API_KEY=your-api-key-here

# Analytics (optional)
REACT_APP_GA_TRACKING_ID=your-ga-tracking-id

# Environment
REACT_APP_ENVIRONMENT=production

# Enable/Disable Features
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_ERROR_REPORTING=false
REACT_APP_ENABLE_PERFORMANCE_MONITORING=false
